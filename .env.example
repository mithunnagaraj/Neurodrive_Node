# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Request Size Limits
MAX_REQUEST_SIZE=10mb

# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TIMEOUT=10000
OPENAI_MAX_RETRIES=2

GEMINI_API_KEY=AIzaSyDclqsU2aIzmHuN6ZAPzExn0i1SZbiQkN8
GEMINI_MODEL=gemini-pro
GEMINI_TIMEOUT=10000
GEMINI_MAX_RETRIES=2

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TIMEOUT=10000
ANTHROPIC_MAX_RETRIES=2

AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name
AZURE_OPENAI_TIMEOUT=10000
AZURE_OPENAI_MAX_RETRIES=2

PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-online
PERPLEXITY_TIMEOUT=10000
PERPLEXITY_MAX_RETRIES=2

# Security
ENCRYPTION_KEY=change_this_to_a_random_32_character_string

# Cache Configuration
CACHE_DEFAULT_TTL=300

# LLM Router Configuration
# Threshold for routing decisions (in characters)
ROUTER_LENGTH_THRESHOLD=100
# Provider for short messages (< threshold)
ROUTER_SHORT_MESSAGE_PROVIDER=gemini
# Provider for long messages (>= threshold)
ROUTER_LONG_MESSAGE_PROVIDER=openai

# Logging
LOG_LEVEL=info
